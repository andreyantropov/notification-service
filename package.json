{
  "name": "notification-service",
  "version": "1.0.0",
  "private": true,
  "description": "Сервис транзакционных уведомлений с поддержкой каналов Bitrix24 и Email. Реализует гибкую доставку через систему стратегий и поддерживает легкое масштабирование новыми каналами и стратегиями отправки.",
  "license": "MIT",
  "author": {
    "name": "Andrey Antropov",
    "email": "andreyantropov.1994@gmail.com"
  },
  "contributors": [
    {
      "name": "Andrey Antropov",
      "email": "andrey.antropov@planarchel.ru"
    }
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "notification-service",
    "bitrix24",
    "email",
    "delivery-strategies",
    "multi-channel",
    "message-routing"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "tsx --watch --env-file=.env.dev --import ./src/instrumentation.ts src/index.ts",
    "build": "tsup src/index.ts src/instrumentation.ts --format esm --splitting --sourcemap --clean --minify --treeshake",
    "start": "node --import ./dist/instrumentation.js ./dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:format": "prettier . --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-express": "^0.61.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@opentelemetry/winston-transport": "^0.23.0",
    "awilix": "^12.0.5",
    "axios": "^1.9.0",
    "express": "^5.1.0",
    "express-async-handler": "^1.2.0",
    "express-oauth2-jwt-bearer": "^1.7.1",
    "express-rate-limit": "^8.2.1",
    "nodemailer": "^7.0.3",
    "p-limit": "^7.3.0",
    "p-timeout": "^6.1.4",
    "serialize-error": "^12.0.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "winston": "^3.18.3",
    "zod": "^3.25.41"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/nodemailer": "^6.4.17",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "^3.2.3",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "^5.4.1",
    "globals": "^17.4.0",
    "openapi-types": "^12.1.3",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "tsx": "^4.20.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.4"
  }
}
